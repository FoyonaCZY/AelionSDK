{
  "name": "@aelion/core",
  "version": "0.1.0-alpha.0",
  "description": "Core time, diagnostics and resource primitives for AelionSDK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FoyonaCZY/AelionSDK.git",
    "directory": "packages/core"
  },
  "keywords": [
    "aelion",
    "video",
    "editing",
    "browser"
  ],
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/.tsbuildinfo"
  ],
  "engines": {
    "node": ">=20.19"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "prepack": "corepack pnpm run build && node ../../scripts/package-artifacts.mjs stage",
    "postpack": "node ../../scripts/package-artifacts.mjs clean"
  }
}
