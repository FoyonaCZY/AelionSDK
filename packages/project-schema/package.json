{
  "name": "@aelion/project-schema",
  "version": "0.1.0-alpha.0",
  "description": "Project v1 types, validation and canonical serialization for AelionSDK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FoyonaCZY/AelionSDK.git",
    "directory": "packages/project-schema"
  },
  "keywords": [
    "aelion",
    "timeline",
    "video",
    "schema"
  ],
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/.tsbuildinfo"
  ],
  "engines": {
    "node": ">=20.19"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "prepack": "corepack pnpm run build && node ../../scripts/package-artifacts.mjs stage",
    "postpack": "node ../../scripts/package-artifacts.mjs clean"
  },
  "dependencies": {
    "@aelion/core": "workspace:*",
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1"
  }
}
