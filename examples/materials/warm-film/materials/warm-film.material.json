{
  "$schema": "https://schemas.aelion.dev/material/definition/v1.json",
  "protocolVersion": "1.0.0",
  "id": "warm-film",
  "kind": "visual-filter",
  "display": {
    "name": "Warm Film",
    "description": "A warm, lightly faded film look.",
    "category": "color",
    "tags": ["warm", "film", "color"]
  },
  "scopes": ["source", "item", "track", "sequence"],
  "ports": [
    {
      "id": "source",
      "direction": "input",
      "type": "visual-frame",
      "role": "source",
      "binding": "host",
      "required": true
    },
    {
      "id": "result",
      "direction": "output",
      "type": "visual-frame",
      "role": "result",
      "binding": "host",
      "required": true
    }
  ],
  "parameters": [
    {
      "id": "intensity",
      "type": "float",
      "default": 0.65,
      "range": {
        "min": 0,
        "max": 1,
        "softMin": 0,
        "softMax": 1,
        "step": 0.01
      },
      "unit": "ratio",
      "animatable": true,
      "interpolation": "linear",
      "affects": "uniform",
      "ui": {
        "control": "slider",
        "group": "look",
        "order": 10,
        "label": "Intensity"
      }
    }
  ],
  "bundledResources": [],
  "resourceSlots": [],
  "execution": {
    "color": {
      "input": "working-linear",
      "output": "working-linear"
    },
    "alpha": {
      "input": "premultiplied",
      "output": "premultiplied",
      "preservesTransparency": true
    },
    "resolution": {
      "policy": "same-as-host"
    },
    "spatialPadding": {
      "mode": "none"
    },
    "temporal": {
      "pastUs": 0,
      "futureUs": 0,
      "stateful": false,
      "seekPolicy": "stateless"
    },
    "determinism": "strict",
    "supports": {
      "realtime": true,
      "offline": true,
      "alpha": true,
      "hdr": true,
      "tiled": true
    }
  },
  "implementations": [
    {
      "type": "graph",
      "graph": "graphs/warm-film.graph.json",
      "nodeSet": "aelion.visual.nodes/1.0.0"
    }
  ],
  "splitPolicy": "copy"
}
