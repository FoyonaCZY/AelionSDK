{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.aelion.dev/fixtures/media-manifest/v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifestVersion", "generator", "fixtures"],
  "properties": {
    "manifestVersion": { "const": "1.0.0" },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "ffmpegVersion"],
      "properties": {
        "command": { "type": "string" },
        "ffmpegVersion": { "type": "string" }
      }
    },
    "fixtures": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "file",
          "sha256",
          "bytes",
          "license",
          "container",
          "features",
          "expected"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "file": {
            "type": "string",
            "pattern": "^fixtures/media/[a-z0-9.-]+$"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "bytes": { "type": "integer", "minimum": 1 },
          "license": { "const": "CC0-1.0" },
          "container": { "enum": ["mp4", "webm"] },
          "features": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" },
            "uniqueItems": true
          },
          "expected": {
            "type": "object",
            "additionalProperties": false,
            "required": ["durationUs", "video", "audio"],
            "properties": {
              "durationUs": { "type": "integer", "minimum": 1 },
              "video": {
                "type": "object",
                "additionalProperties": false,
                "required": ["codecFamily", "width", "height"],
                "properties": {
                  "codecFamily": { "enum": ["avc", "vp9"] },
                  "width": { "type": "integer", "minimum": 1 },
                  "height": { "type": "integer", "minimum": 1 },
                  "firstPresentationUs": { "type": "integer" },
                  "variableFrameRate": { "type": "boolean" },
                  "hasBFrames": { "type": "boolean" }
                }
              },
              "audio": {
                "type": "object",
                "additionalProperties": false,
                "required": ["codecFamily", "sampleRate", "channels"],
                "properties": {
                  "codecFamily": { "enum": ["aac", "opus"] },
                  "sampleRate": { "enum": [44100, 48000, 96000] },
                  "channels": { "type": "integer", "minimum": 1 }
                }
              }
            }
          }
        }
      }
    }
  }
}
